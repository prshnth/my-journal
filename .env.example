# Postgres connection string.
#   - Local dev: the localhost URL below matches docker-compose.yml.
#   - VPS stack (docker-compose.prod.yml): this is overridden to the in-network
#     "db" host automatically, so you can leave the localhost value here.
DATABASE_URL=postgres://journal:journal@localhost:5432/journal

# Telegram bot token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=

# Your IANA timezone, e.g. Asia/Kolkata, America/New_York, Europe/London
USER_TIMEZONE=UTC

# Optional. Leave blank, start the worker, then send your bot "/start" —
# it will capture and store your chat id automatically.
OWNER_TELEGRAM_CHAT_ID=

# --- Dashboard auth (used by the web process) ---
# Protect the dashboard with HTTP Basic Auth. If DASHBOARD_PASSWORD is blank, the
# dashboard is open (fine for localhost; set a strong value before deploying).
DASHBOARD_USER=journal
DASHBOARD_PASSWORD=

# --- Deploy only (docker-compose.prod.yml) ---
# Hostname that points at your VPS. Caddy gets an HTTPS cert for it automatically.
# Use :80 for plain HTTP if you don't have a domain (not recommended — Basic Auth
# credentials would not be encrypted in transit).
DOMAIN=journal.example.com

# Off-box build (docker-compose.deploy.yml): the image you build & push from your
# laptop or CI. A cheap $4/mo server pulls this instead of compiling anything itself.
# Must be all-lowercase. Only used by docker-compose.deploy.yml.
IMAGE=ghcr.io/your-username/my-journal:latest
